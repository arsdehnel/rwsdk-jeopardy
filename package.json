{
	"name": "rwsdk-jeopardy",
	"version": "1.0.0",
	"description": "A simple Jeopardy game built with RedwoodSDK using React Server Components and Cloudflare Workers",
	"main": "index.js",
	"type": "module",
	"keywords": [],
	"author": "",
	"license": "MIT",
	"private": true,
	"scripts": {
		"build": "vite build",
		"dev": "vite dev --host",
		"dev:init": "rw-scripts dev-init",
		"preview": "vite preview",
		"worker:run": "rw-scripts worker-run",
		"clean": "npm run clean:vite",
		"clean:vite": "rm -rf ./node_modules/.vite",
		"release": "rw-scripts ensure-deploy-env && npm run clean && npm run build && wrangler deploy",
		"generate": "rw-scripts ensure-env && wrangler types --include-runtime false",
		"biome:check": "biome check",
		"biome:fix": "biome check --write .",
		"check": "npm run generate && npm run types",
		"type-check": "tsc",
		"prepare": "husky",
		"test": "vitest",
		"test:ui": "vitest --ui",
		"test:run": "vitest run --coverage"
	},
	"dependencies": {
		"@radix-ui/react-icons": "^1.3.2",
		"radix-ui": "^1.4.3",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-server-dom-webpack": "19.2.4",
		"rwsdk": "1.0.0-beta.55"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.13",
		"@cloudflare/vite-plugin": "1.25.1",
		"@cloudflare/workers-types": "4.20260218.0",
		"@commitlint/cli": "^20.4.1",
		"@commitlint/config-conventional": "^20.4.1",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/commit-analyzer": "^13.0.1",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/release-notes-generator": "^14.1.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "~24.10.0",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@vitest/coverage-v8": "4.0.18",
		"@vitest/ui": "4.0.18",
		"conventional-changelog-conventionalcommits": "^9.1.0",
		"husky": "^9.1.7",
		"jsdom": "^28.1.0",
		"less": "^4.5.1",
		"typescript": "5.9.3",
		"vite": "7.3.1",
		"vitest": "^4.0.18",
		"wrangler": "4.66.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"sharp",
			"workerd"
		]
	},
	"packageManager": "pnpm@10.32.1"
}
